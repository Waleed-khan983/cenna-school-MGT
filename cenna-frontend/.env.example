# =============================================================
# CENNA SCHOOL & COLLEGE PABBI — FRONTEND ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in real values.
# Never commit the real .env.local — it's already in .gitignore.
# Both variables are NEXT_PUBLIC_* and end up in the client bundle —
# do not put secrets here.
# =============================================================

# Base URL of the backend API, including the /api prefix.
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Base origin used to resolve legacy "/uploads/..." paths (pre-Cloudinary
# migration records still stored as local paths — see Tier 4 report).
# Should match the backend's own origin (no /api suffix).
NEXT_PUBLIC_FILE_URL=http://localhost:5000
