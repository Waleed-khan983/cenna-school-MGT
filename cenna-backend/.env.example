# =============================================================
# CENNA SCHOOL & COLLEGE PABBI — BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in real values.
# Never commit the real .env — it's already in .gitignore.
# =============================================================

# ── Server ────────────────────────────────────────────────
PORT=5000
# development | production
# In production this also turns autoIndex OFF (index changes must go
# through an explicit, reviewed migration — see utils/indexSync.js) and
# hides stack traces from API error responses.
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────
# MongoDB Atlas connection string (include the database name).
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>

# ── JWT ───────────────────────────────────────────────────
# Use a long, random value in production (e.g. `openssl rand -hex 64`).
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d

# ── Cloudinary (file/image/video uploads) ────────────────
# Required for: admission documents, job-application CVs, avatars,
# lecture attachments, gallery/news images.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# IMPORTANT — Cloudinary dashboard setting still required for lecture
# attachments and admission-document PDFs to be viewable at all:
#   Settings -> Security -> enable PDF/ZIP delivery
# Verify DOC/DOCX/PPT/PPTX delivery separately after enabling — do not
# assume the same toggle covers every format. See DEPLOYMENT.md.

# ── Email (SMTP) ──────────────────────────────────────────
# Confirmation emails (admissions, fee/attendance alerts) fail silently
# and safely if these are wrong or unset — the underlying action (e.g.
# saving an admission) still succeeds either way, but real credentials
# are required for email to actually be delivered.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=
FROM_EMAIL=no-reply@example.com
FROM_NAME="CENNA School & College Pabbi"

# ── Frontend URL (CORS) ───────────────────────────────────
# Comma-separated list for multiple environments, e.g.
# "https://cenna.school,https://staging.cenna.school"
CLIENT_URL=http://localhost:3000

# ── School configuration ──────────────────────────────────
# IANA timezone used for "today's classes" and monthly fee-chart
# grouping. Falls back to Asia/Karachi in code if unset.
SCHOOL_TIMEZONE=Asia/Karachi

# ── Seeder (utils/seeder.js) — used only when running the seed script ──
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Not currently implemented ─────────────────────────────
# utils/helpers.js#sendSMS is a stub (logs to console, sends nothing
# real) — its example integration block is commented out in code. Do
# not set SMS_API_KEY/SMS_SENDER_ID expecting SMS to actually send;
# wiring a real SMS gateway is out of scope until that stub is replaced.
